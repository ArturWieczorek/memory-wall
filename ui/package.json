    "@types/node": "^22.20.1",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "5.9.3",
    "vitest": "^2.1.9"
